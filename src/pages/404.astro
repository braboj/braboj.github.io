---
import Base from '../layouts/Base.astro';
---
<Base title="404 – Page not found">
  <main style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;text-align:center;gap:1rem;">
    <h1 style="font-size:4rem;font-weight:600;color:var(--color-accent);">404</h1>
    <p style="font-size:1.25rem;color:var(--color-text-muted);">Page not found.</p>
    <a href="/" style="color:var(--color-accent);text-decoration:underline;">Back to home</a>
  </main>
</Base>