---
import education from '../data/education.json';
---
<section id="education" class="section">
  <div class="container">
    <h2 class="section-title reveal">Education</h2>
    <div class="education-list">
      {education.map((item) => (
        <div class="education-item reveal">
          <div class="education-header">
            <div>
              <span class="education-institution">{item.institution}</span>
              <span class="education-degree">{item.degree}</span>
            </div>
            <span class="education-period">{item.period}</span>
          </div>
          <p class="education-location">{item.location}</p>
        </div>
      ))}
    </div>
  </div>
</section>