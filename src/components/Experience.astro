---
import experience from '../data/experience.json';
---
<section id="experience" class="section">
  <div class="container">
    <h2 class="section-title reveal">Experience</h2>
    <div class="experience-list">
      {experience.map((item) => (
        <div class="experience-item reveal">
          <div class="experience-header">
            <div>
              <span class="experience-company">{item.company}</span>
              <span class="experience-role">{item.role}</span>
            </div>
            <span class="experience-period">{item.period}</span>
          </div>
          <p class="experience-description">{item.description}</p>
          <div class="tags">
            {item.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>