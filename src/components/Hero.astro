---
import site from '../data/site.json';
---
<section class="hero">
  <div class="container">
    <p class="hero-eyebrow"><a href="https://github.com/braboj/braboj.github.io">braboj.github.io</a></p>
    <h1 class="hero-title">{site.title}</h1>
    <p class="hero-summary">{site.summary}</p>
    <div class="hero-actions">
      <a href="#contact" class="btn btn-primary">Get in touch</a>
      <a href="#experience" class="btn btn-secondary">See experience</a>
      <a href="/cv/CV_Branimir_Georgiev.pdf" class="btn btn-secondary" download>Download CV</a>
    </div>
  </div>
</section>