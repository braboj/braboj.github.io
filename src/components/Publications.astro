---
import publications from '../data/publications.json';
---
<section id="publications" class="section section-alt">
  <div class="container">
    <h2 class="section-title reveal">Publications</h2>
    <div class="publications-list">
      {publications.map((pub) => (
        <div class="publication-item reveal">
          <p class="publication-title">
            <a
              href={pub.doi}
              target="_blank"
              rel="noopener noreferrer"
            >{pub.title}</a>
          </p>
          <p class="publication-journal">{pub.journal}</p>
          <p class="publication-meta">{pub.authors} — {pub.ref}</p>
        </div>
      ))}
    </div>
  </div>
</section>